{
"compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "declaration": false,
    "noImplicitAny": false,
    "removeComments": true,
    "noLib": false,
    "outDir": "./build",
    "rootDir": "./script",
    "skipLibCheck": true
},
"include": [
    "script/*.ts",
]
}
